# Caches Python e arquivos compilados
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Ambientes virtuais locais
.venv/
venv/
env/

# Variáveis locais e credenciais
.env

# Logs operacionais gerados pelo Airflow
logs/*
!logs/.gitkeep

# Arquivos temporários do sistema operacional
.DS_Store
Thumbs.db

# Configurações locais de IDE
.vscode/
.idea/

# Bancos locais criados por testes ou validações manuais
*.sqlite
*.sqlite3

# Arquivo local de orientação operacional do ambiente de desenvolvimento
AGENTS.md

# Documentos editáveis de evidências não fazem parte da entrega final versionada
relatorio/evidencias/*.docx
